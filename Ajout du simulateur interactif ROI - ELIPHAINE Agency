      <p class="footer-text">Calculs basés sur nos modèles de rentabilité éprouvés. Résultats donnés à titre indicatif.</p>
    </footer>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <button class="modal-close" id="closeModal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- Form State -->
      <div class="form-state" id="formState">
        <h3 class="modal-title">Demande de Diagnostic Prioritaire</h3>
        <p class="modal-description">
          Notre agenda de diagnostics stratégiques est actuellement complet pour cette semaine. 
          Laissez-nous vos coordonnées pour être recontacté en priorité dès qu'un créneau se libère.
        </p>

        <form id="waitlistForm">
          <div class="form-group">
            <label class="form-label" for="fullName">Nom complet</label>
            <input type="text" class="form-input" id="fullName" placeholder="Jean Dupont" required>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email professionnel</label>
            <input type="email" class="form-input" id="email" placeholder="jean.dupont@entreprise.com" required>
          </div>

          <button type="submit" class="submit-button" id="submitBtn">
            <span id="submitText">Rejoindre la liste d'attente</span>
            <div class="spinner" id="spinner" style="display: none;"></div>
          </button>
        </form>

        <div class="modal-footer">
          <p class="modal-footer-text">Vos données restent strictement confidentielles et souveraines. Réponse sous 24h.</p>
        </div>
      </div>

      <!-- Success State -->
      <div class="success-state" id="successState">
        <div class="success-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3 class="success-title">Inscription Confirmée</h3>
        <p class="success-text" id="successText">
          Merci ! Nous vous contacterons très prochainement.
        </p>
        <button class="close-button" id="successClose">Fermer</button>
      </div>
    </div>
  </div>

  <script>
    // DOM Elements
    const teamSizeInput = document.getElementById('teamSize');
    const hoursPerWeekInput = document.getElementById('hoursPerWeek');
    const hourlyRateInput = document.getElementById('hourlyRate');
    
    const teamSizeValue = document.getElementById('teamSizeValue');
    const hoursValue = document.getElementById('hoursValue');
    const rateValue = document.getElementById('rateValue');
    
    const teamSizeFill = document.getElementById('teamSizeFill');
    const hoursFill = document.getElementById('hoursFill');
    const rateFill = document.getElementById('rateFill');
    
    const teamSizeThumb = document.getElementById('teamSizeThumb');
    const hoursThumb = document.getElementById('hoursThumb');
    const rateThumb = document.getElementById('rateThumb');
    
    const hoursSaved = document.getElementById('hoursSaved');
    const moneySaved = document.getElementById('moneySaved');
    const percentage = document.getElementById('percentage');
    const radialProgress = document.getElementById('radialProgress');
    
    const modalOverlay = document.getElementById('modalOverlay');
    const openModalBtn = document.getElementById('openModal');
    const closeModalBtn = document.getElementById('closeModal');
    const waitlistForm = document.getElementById('waitlistForm');
    const formState = document.getElementById('formState');
    const successState = document.getElementById('successState');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const spinner = document.getElementById('spinner');
    const successClose = document.getElementById('successClose');
    const successText = document.getElementById('successText');
    const fullNameInput = document.getElementById('fullName');
    const emailInput = document.getElementById('email');

    // Constants
    const AUTOMATION_RATE = 0.8;
    const WEEKS_PER_YEAR = 52;
    const CIRCUMFERENCE = 2 * Math.PI * 42;

    // Format currency
    function formatCurrency(num) {
      return new Intl.NumberFormat('fr-FR', {
        style: 'currency',
        currency: 'EUR',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format(num);
    }

    // Format hours
    function formatHours(num) {
      return new Intl.NumberFormat('fr-FR').format(num) + 'h';
    }

    // Update slider visual
    function updateSlider(input, fill, thumb, value, suffix = '', min, max) {
      const percent = ((input.value - min) / (max - min)) * 100;
      fill.style.width = percent + '%';
      thumb.style.left = percent + '%';
      value.textContent = input.value + suffix;
    }

    // Calculate results
    function calculateResults() {
      const teamSize = parseInt(teamSizeInput.value);
      const hoursPerWeek = parseInt(hoursPerWeekInput.value);
      const hourlyRate = parseInt(hourlyRateInput.value);

      const annualManualHours = teamSize * hoursPerWeek * WEEKS_PER_YEAR;
      const annualSavedHours = Math.round(annualManualHours * AUTOMATION_RATE);
      const annualSavings = annualSavedHours * hourlyRate;
      const percentageValue = Math.round(AUTOMATION_RATE * 100);

      // Update displays
      hoursSaved.textContent = formatHours(annualSavedHours);
      moneySaved.textContent = formatCurrency(annualSavings);
      percentage.textContent = percentageValue + '%';

      // Update radial chart
      const offset = CIRCUMFERENCE - (percentageValue / 100) * CIRCUMFERENCE;
      radialProgress.style.strokeDashoffset = offset;
    }

    // Initialize sliders
    function initSliders() {
      updateSlider(teamSizeInput, teamSizeFill, teamSizeThumb, teamSizeValue, '', 1, 500);
      updateSlider(hoursPerWeekInput, hoursFill, hoursThumb, hoursValue, 'h', 1, 20);
      updateSlider(hourlyRateInput, rateFill, rateThumb, rateValue, ' €', 15, 150);
      calculateResults();
    }

    // Event Listeners for sliders
    teamSizeInput.addEventListener('input', () => {
      updateSlider(teamSizeInput, teamSizeFill, teamSizeThumb, teamSizeValue, '', 1, 500);
      calculateResults();
    });

    hoursPerWeekInput.addEventListener('input', () => {
      updateSlider(hoursPerWeekInput, hoursFill, hoursThumb, hoursValue, 'h', 1, 20);
      calculateResults();
    });

    hourlyRateInput.addEventListener('input', () => {
      updateSlider(hourlyRateInput, rateFill, rateThumb, rateValue, ' €', 15, 150);
      calculateResults();
    });

    // Modal functions
    function openModal() {
      modalOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modalOverlay.classList.remove('active');
      document.body.style.overflow = '';
      
      // Reset form after animation
      setTimeout(() => {
        formState.classList.remove('hidden');
        successState.classList.remove('active');
        waitlistForm.reset();
      }, 300);
    }

    // Modal event listeners
    openModalBtn.addEventListener('click', openModal);
    closeModalBtn.addEventListener('click', closeModal);
    successClose.addEventListener('click', closeModal);

    modalOverlay.addEventListener('click', (e) => {
      if (e.target === modalOverlay) {
        closeModal();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modalOverlay.classList.contains('active')) {
        closeModal();
      }
    });

    // Form submission
    waitlistForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      submitBtn.disabled = true;
      submitText.style.display = 'none';
      spinner.style.display = 'block';

      // Simulate API call
      await new Promise(resolve => setTimeout(resolve, 1500));

      // Get form data
      const fullName = fullNameInput.value;
      const email = emailInput.value;
      const firstName = fullName.split(' ')[0];

      // Update success message
      successText.textContent = `Merci ${firstName} ! Nous vous contacterons très prochainement à l'adresse ${email}.`;

      // Show success state
      formState.classList.add('hidden');
      successState.classList.add('active');

      // Reset button
      submitBtn.disabled = false;
      submitText.style.display = 'inline';
      spinner.style.display = 'none';
    });

    // Initialize
    initSliders();
  </script>
</body>
</html>
